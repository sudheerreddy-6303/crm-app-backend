# Copy this file to .env and fill in your values

# MySQL (Railway gives you these in the MySQL service > Variables tab)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=telecrm

# Server
PORT=5000

# Security - generate a long random string, e.g. run:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=put-a-long-random-string-here

# First admin account (created automatically on first run)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=SetAStrongPasswordHere

# ADDED: Deployed application URLs
# Frontend URL - used for CORS (only this origin + localhost can call the API when set)
FRONTEND_URL=https://your-frontend.onrender.com
# Backend URL - for reference (this service itself)
BACKEND_URL=https://your-backend.onrender.com
